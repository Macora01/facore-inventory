# ═══════════════════════════════════════════
# Facore Inventory — Variables de Producción
# ═══════════════════════════════════════════
# Copia este archivo como .env y cambia todos los valores.

# ── Base de Datos ──
POSTGRES_USER=facore
POSTGRES_PASSWORD=cambia-por-password-seguro
POSTGRES_DB=facore

# ── App ──
PORT=3000

# ── Autenticación ──
# Generar con: openssl rand -hex 32
JWT_SECRET=cambia-por-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=24h

# ── Admin Inicial ──
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-por-password-seguro

# ── CORS ──
ALLOWED_ORIGINS=https://inv.facore.cl
